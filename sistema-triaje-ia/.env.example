# Configuración del Sistema de Triaje Multimodal IA
# Copiar a .env y ajustar valores según entorno

# Base de datos
DB_PATH=data/triaje.db

# Seguridad
SESSION_TIMEOUT_MINUTES=15
BCRYPT_ROUNDS=12

# Modelo IA
MODEL_PATH=models/
ACTIVE_MODEL=xgboost_early_fusion_v1

# Entorno
ENV=development
LOG_LEVEL=INFO
