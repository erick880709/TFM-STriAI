# =============================================================================
# .env — Variables de entorno para despliegue Docker de STriAI
# =============================================================================
# Copia este archivo como .env y ajusta los valores según tu entorno.
# El docker-compose.yml lee automáticamente este archivo.
# =============================================================================

# ---------------------------------------------------------------------------
# Puerto de Streamlit
# ---------------------------------------------------------------------------
STREAMLIT_PORT=8501

# ---------------------------------------------------------------------------
# Base de datos
# ---------------------------------------------------------------------------
DB_PATH=data/triaje.db

# ---------------------------------------------------------------------------
# Seguridad
# ---------------------------------------------------------------------------
SESSION_TIMEOUT_MINUTES=15
BCRYPT_ROUNDS=12

# ---------------------------------------------------------------------------
# Modelo IA
# ---------------------------------------------------------------------------
MODEL_PATH=/app/models/
ACTIVE_MODEL=early_fusion_v20260720_224350

# ---------------------------------------------------------------------------
# JWT (para API REST futura — FastAPI)
# ---------------------------------------------------------------------------
JWT_SECRET=cambiar-por-secreto-seguro-en-produccion
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=15

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173,http://localhost:8501

# ---------------------------------------------------------------------------
# Entorno
# ---------------------------------------------------------------------------
ENV=production
LOG_LEVEL=INFO
