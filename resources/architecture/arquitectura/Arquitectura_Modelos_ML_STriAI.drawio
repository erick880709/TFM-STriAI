        <mxCell id="mt2-s" value="—" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#161B22;strokeColor=#30363D;fontColor=#C9D1D9;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="400" y="870" width="80" height="25" as="geometry" />
        </mxCell>

        <!-- Notes -->
        <mxCell id="notes-box" value="&lt;b&gt;Notas&lt;/b&gt;&lt;br&gt;• Early Fusion gana en F1 Macro pero no detecta Niveles I ni V&lt;br&gt;• Late Fusion es el único que detecta las 5 clases (útil clínicamente)&lt;br&gt;• AUC-ROC = 0.00 es un bug de sklearn 1.9+ (requiere investigación)&lt;br&gt;• SHAP no funcional por incompatibilidad XGBoost 3.2 + SHAP 0.51" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#161B22;strokeColor=#D2991D;fontColor=#8B949E;fontSize=10;verticalAlign=top;align=left;spacingLeft=10;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="800" y="780" width="600" height="100" as="geometry" />
        </mxCell>

